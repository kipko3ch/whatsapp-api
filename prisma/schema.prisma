generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  member
  agent
}

enum DeviceStatus {
  disconnected
  qr_required
  connecting
  connected
  logged_out
  banned
  error
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  text
  image
  document
  audio
  video
  location
  contact
  interactive
}

enum MessageStatus {
  queued
  sending
  sent
  delivered
  read
  received
  failed
}

enum WebhookEvent {
  message_received
  message_sent
  message_delivered
  message_read
  message_failed
  device_connected
  device_disconnected
  contact_updated
  campaign_completed
}

enum DeliveryStatus {
  pending
  delivered
  failed
  retrying
}

enum CampaignStatus {
  draft
  scheduled
  running
  paused
  completed
  canceled
  failed
}

enum RecipientStatus {
  pending
  queued
  sent
  delivered
  failed
  skipped
  opted_out
  blacklisted
}

enum SendJobStatus {
  queued
  running
  completed
  failed
  retrying
  canceled
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(owner)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces WorkspaceMember[]
  auditLogs  AuditLog[]
  apiKeys    ApiKey[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            WorkspaceMember[]
  apiKeys            ApiKey[]
  devices            WhatsappDevice[]
  contacts           Contact[]
  conversations      Conversation[]
  messages           Message[]
  webhooks           Webhook[]
  webhookDeliveries  WebhookDelivery[]
  bulkCampaigns      BulkCampaign[]
  sendJobs           SendJob[]
  auditLogs          AuditLog[]
  optOuts            OptOut[]
  blacklistedNumbers BlacklistedNumber[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole @default(member)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  name        String
  keyPrefix   String
  keyHash     String    @unique
  scopes      String[]
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WhatsappDevice {
  id                    String       @id @default(cuid())
  workspaceId           String
  name                  String
  phoneNumber           String?
  jid                   String?
  status                DeviceStatus @default(disconnected)
  statusReason          String?
  lastQr                String?
  lastQrAt              DateTime?
  lastSeenAt            DateTime?
  connectedAt           DateTime?
  dailySendLimit        Int          @default(250)
  currentDailySentCount Int          @default(0)
  dailyCounterDate      DateTime?
  health                Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions      WhatsappSession[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  bulkCampaigns BulkCampaign[]
  sendJobs      SendJob[]

  @@index([workspaceId, status])
  @@index([phoneNumber])
}

model WhatsappSession {
  id        String   @id @default(cuid())
  deviceId  String
  keyType   String
  keyId     String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  device WhatsappDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, keyType, keyId])
  @@index([deviceId])
}

model Contact {
  id            String    @id @default(cuid())
  workspaceId   String
  deviceId      String?
  phone         String
  jid           String?
  name          String?
  pushName      String?
  tags          String[]  @default([])
  metadata      Json?
  optedOutAt    DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  device        WhatsappDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  messages      Message[]

  @@unique([workspaceId, phone])
  @@index([workspaceId, lastMessageAt])
}

model Conversation {
  id            String    @id @default(cuid())
  workspaceId   String
  deviceId      String
  contactId     String?
  contactPhone  String
  title         String?
  humanTakeover Boolean   @default(false)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  device    WhatsappDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  contact   Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@unique([deviceId, contactPhone])
  @@index([workspaceId, lastMessageAt])
}

model Message {
  id             String           @id @default(cuid())
  workspaceId    String
  deviceId       String
  conversationId String?
  contactId      String?
  contactPhone   String
  externalId     String?
  direction      MessageDirection
  type           MessageType
  status         MessageStatus    @default(queued)
  text           String?
  payload        Json?
  errorCode      String?
  errorMessage   String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  device       WhatsappDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  media        MessageMedia[]
  sendJobs     SendJob[]

  @@unique([deviceId, externalId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, direction, status])
  @@index([contactPhone])
}

model MessageMedia {
  id        String      @id @default(cuid())
  messageId String
  type      MessageType
  url       String?
  mimeType  String?
  fileName  String?
  sizeBytes Int?
  sha256    String?
  metadata  Json?
  createdAt DateTime    @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Webhook {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  url           String
  events        WebhookEvent[]
  secret        String
  active        Boolean        @default(true)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id            String         @id @default(cuid())
  workspaceId   String
  webhookId     String?
  event         WebhookEvent
  payload       Json
  signature     String?
  status        DeliveryStatus @default(pending)
  attempt       Int            @default(0)
  nextAttemptAt DateTime?
  responseCode  Int?
  responseBody  String?
  errorMessage  String?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhook   Webhook?  @relation(fields: [webhookId], references: [id], onDelete: SetNull)

  @@index([workspaceId, event, status])
}

model BulkCampaign {
  id                 String         @id @default(cuid())
  workspaceId        String
  deviceId           String?
  name               String
  status             CampaignStatus @default(draft)
  messageType        MessageType    @default(text)
  messageText        String?
  payload            Json?
  rateLimitPerMinute Int            @default(10)
  delayMinMs         Int            @default(5000)
  delayMaxMs         Int            @default(15000)
  maxRetries         Int            @default(2)
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  pausedAt           DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  workspace  Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  device     WhatsappDevice?         @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  recipients BulkCampaignRecipient[]
  sendJobs   SendJob[]

  @@index([workspaceId, status])
}

model BulkCampaignRecipient {
  id           String          @id @default(cuid())
  campaignId   String
  phone        String
  name         String?
  variables    Json?
  status       RecipientStatus @default(pending)
  messageId    String?
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  campaign BulkCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, phone])
  @@index([campaignId, status])
}

model SendJob {
  id             String        @id @default(cuid())
  workspaceId    String
  deviceId       String
  campaignId     String?
  messageId      String?
  recipientPhone String
  payload        Json
  status         SendJobStatus @default(queued)
  attempts       Int           @default(0)
  maxAttempts    Int           @default(3)
  runAt          DateTime      @default(now())
  lockedAt       DateTime?
  completedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  device    WhatsappDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  campaign  BulkCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  message   Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, runAt])
  @@index([deviceId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  actorType   String
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

model OptOut {
  id          String   @id @default(cuid())
  workspaceId String
  phone       String
  reason      String?
  source      String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, phone])
}

model BlacklistedNumber {
  id          String   @id @default(cuid())
  workspaceId String
  phone       String
  reason      String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, phone])
}
